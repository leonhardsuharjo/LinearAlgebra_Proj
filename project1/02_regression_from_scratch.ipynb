   "source": [
    "#standardization \n",
    "def standardize(X):\n",
    "    mu = X.mean(axis=0)\n",
    "    sigma = X.std(axis=0, ddof=0)\n",
    "    return (X - mu) / sigma, mu, sigma\n"
   ]
  }
